# ─────────────────────────────────────────────
# JIRA Configuration
# ─────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=prashant.chavan@technia.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJs

# ─────────────────────────────────────────────
# Bitbucket Configuration
# ─────────────────────────────────────────────
BITBUCKET_WORKSPACE=your-workspace
BITBUCKET_REPO_SLUG=your-repo-slug
BITBUCKET_TOKEN=your_bitbucket_access_token
BITBUCKET_BASE_BRANCH=main

# ─────────────────────────────────────────────
# OpenAI Configuration
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# Code generation model. Options (best → good):
#   codex-mini-latest   OpenAI Codex (2025) — uses Responses API  ← RECOMMENDED
#   o3-mini             Reasoning model     — uses Responses API
#   gpt-4o              GPT-4o              — uses Chat Completions API
#
# NOTE: codex-mini-latest and o3-mini use a different API internally.
#       The agent handles this automatically — just set the model name.
OPENAI_MODEL=codex-mini-latest

# Embedding model used for semantic file retrieval (NOT code generation).
# text-embedding-3-small is the recommended choice: fast, cheap, accurate.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─────────────────────────────────────────────
# Agent Configuration
# ─────────────────────────────────────────────
# Local directory where repos will be cloned
CLONE_BASE_PATH=./workspaces

# Max attempts to fix errors before opening a draft PR
MAX_FIX_ATTEMPTS=3

# Command used to test the application after AI makes changes
APP_START_COMMAND=npm test

# Timeout (ms) to wait for test run to complete
APP_TIMEOUT_MS=30000

# ─────────────────────────────────────────────
# Semantic Retrieval (Large Repo Support)
# ─────────────────────────────────────────────
# Number of files to include with FULL content (selected by semantic similarity).
# Remaining files appear in the Repo Map with a 1-line purpose summary only.
# Increase for complex tasks; decrease to reduce token usage.
TOP_K_FULL_CONTEXT=20

# Set to 'true' to skip embedding/indexing and fall back to raw concatenation.
# Only use this for very small repos (< 20 files). Large repos WILL be truncated.
SKIP_INDEXING=false
